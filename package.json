{
  "name": "effect-slack",
  "version": "0.3.2",
  "description": "An Effect-native Slack SDK",
  "keywords": [
    "api",
    "effect",
    "functional",
    "slack",
    "typescript",
    "web-api"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MateoKruk/effect-slack"
  },
  "files": [
    "dist",
    "LICENSE",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --ignore-pattern 'vendor/effect-smol/**'",
    "lint:fix": "oxlint . --fix --ignore-pattern 'vendor/effect-smol/**'",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "generate": "bun scripts/generate-services.ts",
    "generate:check": "bun scripts/generate-services.ts --check",
    "prepublishOnly": "bun run build",
    "prepare": "husky",
    "changeset": "changeset",
    "release": "changeset publish",
    "example:platform": "cd examples/with-effect-platform && bun run dev",
    "example:express": "cd examples/with-express && bun run dev"
  },
  "dependencies": {
    "@slack/web-api": "^7.18.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@effect/platform-bun": "^4.0.0-beta.93",
    "@effect/platform-node": "^4.0.0-beta.93",
    "@effect/vitest": "^4.0.0-beta.93",
    "@types/bun": "^1.3.14",
    "effect": "^4.0.0-beta.93",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.93"
  },
  "lint-staged": {
    "{src,scripts,test,examples}/**/*.{js,jsx,ts,tsx}": "oxlint",
    "{src,scripts,test,examples}/**/*": "oxfmt --write --no-error-on-unmatched-pattern",
    "package.json": "oxfmt --write"
  },
  "engines": {
    "node": ">=18"
  }
}
